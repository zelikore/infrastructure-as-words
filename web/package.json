{
  "name": "@infrastructure-as-words/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace @infrastructure-as-words/contracts && tsx ../scripts/build-web-export.ts --env dev && tsx ../scripts/build-web-export.ts --env prod",
    "clean": "rm -rf .next out public/runtime-config.json tsconfig.tsbuildinfo",
    "dev": "next dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@infrastructure-as-words/contracts": "*",
    "@xyflow/react": "^12.10.2",
    "next": "^16.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
