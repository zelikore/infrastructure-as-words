{
  "name": "@infrastructure-as-words/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && tsx ../../scripts/build-api.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1033.0",
    "@aws-sdk/client-cloudwatch": "^3.1033.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1033.0",
    "@aws-sdk/client-dynamodb": "^3.936.0",
    "@aws-sdk/client-lambda": "^3.1033.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/client-sns": "^3.1033.0",
    "@aws-sdk/client-ssm": "^3.1033.0",
    "@aws-sdk/lib-dynamodb": "^3.936.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@infrastructure-as-words/contracts": "*",
    "fflate": "^0.8.2",
    "zod": "^4.1.12"
  }
}
